# ==========================================================
# FUTURE SAFE HER — BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to version control.
# ==========================================================

# ---------- SERVER ----------
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
API_BASE_URL=http://localhost:5000

# ---------- DATABASE ----------
# If you leave MONGODB_URI empty in development, the app will use an in-memory MongoDB server automatically.
MONGODB_URI=

# ---------- JWT AUTH ----------
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# ---------- BCRYPT ----------
BCRYPT_SALT_ROUNDS=12

# ---------- CLOUDINARY (profile images, voice recordings, evidence vault) ----------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---------- FIREBASE CLOUD MESSAGING (push notifications) ----------
# Paste the full service-account JSON as a single-line string, or
# provide a path to the service account file instead.
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nAIzaSyCTA455KsowmZmdp3oNaprrv3ABTnQxhs0\n-----END PRIVATE KEY-----\n"

# ---------- GROQ AI CHATBOT ----------
# Chatbot uses ONLY Groq — never OpenAI.
GROQ_API_KEY=YOUR_GROQ_API_KEY

GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# ---------- NODEMAILER (forgot / reset password emails) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Future Safe Her
SMTP_FROM_EMAIL=no-reply@futuresafeher.ai

# ---------- RATE LIMITING ----------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
SOS_RATE_LIMIT_MAX=10

# ---------- ROUTING / MAPS (no key required — OSRM + OpenStreetMap Overpass) ----------
OSRM_BASE_URL=https://router.project-osrm.org
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
GOOGLE_MAPS_BASE_URL=https://www.google.com/maps

# ---------- SOCKET.IO ----------
SOCKET_CORS_ORIGIN=http://localhost:5173
